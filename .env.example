# Application
APP_NAME=AI Job Automation
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY=your-api-key-here

# Database
DATABASE_URL=postgresql+asyncpg://jobuser:jobpass@localhost:5432/jobautomation
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=86400

# Storage (S3/R2)
STORAGE_PROVIDER=s3
STORAGE_BUCKET=job-automation
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_ENDPOINT=  # For R2 custom endpoint

# GitHub
GITHUB_TOKEN=your-github-token

# AI Providers
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Email (Gmail)
GMAIL_CREDENTIALS_FILE=credentials.json
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ALERTS_FROM_EMAIL=alerts@example.com
ALERTS_TO_EMAIL=admin@example.com
EMAIL_ALERTS_ENABLED=false

# Scraping
SCRAPE_INTERVAL_HOURS=4
SCRAPER_KEYWORDS=python,fastapi,react,aws
SCRAPER_LOCATION=United States
RATE_LIMIT_DELAY=2.0
MAX_RETRIES=3

# Job Sources
LINKEDIN_ENABLED=true
LINKEDIN_EMAIL=your-linkedin-email
LINKEDIN_PASSWORD=your-linkedin-password
ADZUNA_ENABLED=true
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key
REMOTIVE_ENABLED=true
ARBEITNOW_ENABLED=true
RSS_FEEDS=https://example.com/feed.xml,https://another.com/feed.xml

# Workflow
USE_TEMPORAL=false  # Set to true to use Temporal instead of Celery
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000